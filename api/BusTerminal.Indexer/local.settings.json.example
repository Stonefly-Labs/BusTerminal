{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "COSMOS_DATABASE_NAME": "canonical",
    "COSMOS_REGISTRY_ENTITIES_CONTAINER": "registry-entities",
    "COSMOS_REGISTRY_LEASES_CONTAINER": "registry-entities-leases",

    "Cosmos__accountEndpoint": "https://<dev-cosmos-name>.documents.azure.com:443/",
    "Cosmos__credential": "managedidentity",
    "Cosmos__clientId": "<workload-uami-client-id>",

    "AI_SEARCH_ENDPOINT": "https://<dev-ai-search-name>.search.windows.net",
    "AI_SEARCH_INDEX_NAME": "registry-entities-v1",

    "APPLICATIONINSIGHTS_CONNECTION_STRING": "<connection-string-from-kv>",
    "OTEL_SERVICE_NAME": "busterminal-indexer"
  }
}
