{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Function.RegistryEntityIndexer": "Information",
      "Microsoft.Azure.WebJobs.Hosting": "Warning"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "cosmosDB": {
      "logLevel": {
        "default": "Information"
      }
    }
  }
}
