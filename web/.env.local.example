# BusTerminal frontend — local development environment template.
# Copy to .env.local and fill in the values for your target Entra tenant.
# .env.local is gitignored; this .example file is the source-controlled template.
#
# These variables configure MSAL (`@azure/msal-browser` + `@azure/msal-react`)
# for the SPA. Authentication is Authorization Code + PKCE against Entra ID —
# no client secret is required on the frontend. See specs/003-auth-and-identity/
# quickstart.md § C.3 for the dev-tenant values.
#
# NOTE: NEXT_PUBLIC_* variables are inlined into the client bundle at build
# time. Never put a secret in any NEXT_PUBLIC_* variable. App-registration ids
# and tenant ids are not secrets — they are public Entra identifiers.

# The Entra ID tenant that owns the BusTerminal app registrations.
NEXT_PUBLIC_AZURE_AD_TENANT_ID=

# The application (client) id of the SPA app registration (bt-*-web).
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=

# The scope MSAL requests when acquiring an access token for the BusTerminal
# backend API. Format: api://<api-app-client-id>/.default
NEXT_PUBLIC_API_SCOPE=

# Base URL of the BusTerminal backend API for the local stack. The api-client
# prepends this to every request and propagates W3C traceparent headers.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
