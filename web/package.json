{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:storybook": "test-storybook",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm build-storybook --quiet && http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && pnpm test:storybook\"",
    "test:e2e": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/a11y",
    "analyze": "cross-env ANALYZE=true next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "audit:strings": "node scripts/audit-strings.mjs",
    "audit:directions": "node scripts/audit-directions.mjs",
    "audit:svg-hygiene": "node scripts/audit-svg-hygiene.mjs",
    "audit:review-records": "node scripts/audit-review-records.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^4",
    "@azure/msal-react": "^3",
    "@hookform/resolvers": "^3.9.1",
    "@microsoft/applicationinsights-react-js": "^17.3.6",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@radix-ui/react-checkbox": "^1.1.6",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.1.3",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "^16",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.76.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^3.8.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/nextjs": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "vitest-axe": "^0.1.0",
    "wait-on": "^9.0.10"
  },
  "pnpm": {
    "overrides": {
      "@nevware21/ts-utils": ">=0.13.1"
    }
  }
}
